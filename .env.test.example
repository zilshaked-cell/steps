# Copy to .env.test and fill in. Never commit .env.test itself (already covered by
# the .env* rule in .gitignore).
#
# Must point at a database dedicated to integration tests — NOT steps_dev. The
# harness truncates every app table before each test file; running it against a
# database you care about will destroy its data.
#
# One-time setup (reusing the existing `steps` dev role, just a different database):
#   psql -U postgres -h 127.0.0.1 -c "CREATE DATABASE steps_test OWNER steps;"

TEST_DATABASE_URL="postgresql://steps:steps_dev_password@localhost:5432/steps_test?schema=public"
