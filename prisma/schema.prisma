// Prisma schema.
// Scope note: only the "Stage Programs" (תכניות שלבים) domain is modeled in depth here,
// per current spec. Other future domains (yearly plans, token plans, day summaries) are
// intentionally NOT modeled yet — do not invent structures for them ahead of their own spec.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Organization: Institution / Group / Trainee / Staff
// ---------------------------------------------------------------------------

model Institution {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups             Group[]
  trainees           Trainee[]
  staff              StaffUser[]
  rolePermissions    RolePermission[]
  userOverrides      UserPermissionOverride[]
  stagePrograms      StageProgram[]
  scoringProfiles    ScoringProfile[]
  measurementReports MeasurementReport[]
  vacations          VacationPeriod[]
  groupMemberships   TraineeGroupMembershipHistory[]
  settingsChangeLog  SettingsChangeLogEntry[]
  auditLogEntries    AuditLogEntry[]
}

model Group {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  description   String?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt

  trainees              Trainee[]
  staffAssignments      GroupStaffAssignment[]
  permissionScopes      UserPermissionOverride[]
  scoringProfiles       ScoringProfile[]
  vacations             VacationPeriod[]
  measurementReports    MeasurementReport[]
  membershipHistoryFrom TraineeGroupMembershipHistory[] @relation("MembershipFromGroup")
  membershipHistoryTo   TraineeGroupMembershipHistory[] @relation("MembershipToGroup")

  @@index([institutionId])
  @@index([institutionId, active])
}

// Staff hierarchy, highest to lowest, per current spec:
// ADMIN (מנהל/רכז פנימייה) > LEAD_COORDINATOR (רכז/מדריך מוביל) > COUNSELOR (מדריך) > YOUTH_WORKER (ש"ש)
// TRAINEE is included because trainees also get a limited login (ממשק חניך), not yet spec'd in depth.
enum StaffRole {
  ADMIN
  LEAD_COORDINATOR
  COUNSELOR
  YOUTH_WORKER
  TRAINEE
}

model StaffUser {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  email         String      @unique
  // Legacy dev password hash from the earlier Credentials-provider bootstrap.
  // Current login uses Google OAuth and maps the verified Google email to this StaffUser row.
  passwordHash  String?
  role          StaffRole
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())

  // Set only for TRAINEE-role logins, linking the account to the trainee it represents.
  traineeId String?  @unique
  trainee   Trainee? @relation("TraineeLogin", fields: [traineeId], references: [id])

  groupAssignments             GroupStaffAssignment[]
  permissionOverrides          UserPermissionOverride[]
  stageChangesPerformed        StageChangeEvent[]              @relation("StageChangePerformedBy")
  scoreEntriesRecorded         ScoreEntry[]                    @relation("ScoreEntryRecordedBy")
  measurementReportsRecorded   MeasurementReport[]             @relation("MeasurementReportRecordedBy")
  measurementReportsPublished  MeasurementReport[]             @relation("MeasurementReportPublishedBy")
  groupMovesPerformed          TraineeGroupMembershipHistory[] @relation("GroupMovePerformedBy")
  stageProgramVersionsCreated  StageProgramVersion[]           @relation("StageProgramVersionCreatedBy")
  stageProgramVersionsReplaced StageProgramVersion[]           @relation("StageProgramVersionReplacedBy")
  scoringProfilesCreated       ScoringProfile[]                @relation("ScoringProfileCreatedBy")
  scoringProfilesPublished     ScoringProfile[]                @relation("ScoringProfilePublishedBy")
  vacationsCreated             VacationPeriod[]                @relation("VacationCreatedBy")
  settingsChangesMade          SettingsChangeLogEntry[]        @relation("SettingsChangedBy")
  auditLogEntries              AuditLogEntry[]

  @@index([institutionId])
}

model GroupStaffAssignment {
  id        String    @id @default(cuid())
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id])
  staffId   String
  staff     StaffUser @relation(fields: [staffId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([groupId, staffId])
  @@index([staffId])
}

// Whether a trainee follows the institution's default stage-program configuration
// or has an individually customized measurement/threshold setup for it.
enum MeasurementMode {
  STANDARD
  CUSTOM
}

model Trainee {
  id              String          @id @default(cuid())
  institutionId   String
  institution     Institution     @relation(fields: [institutionId], references: [id])
  groupId         String?
  group           Group?          @relation(fields: [groupId], references: [id])
  firstName       String
  lastName        String
  active          Boolean         @default(true)
  measurementMode MeasurementMode @default(STANDARD)
  createdAt       DateTime        @default(now())

  currentStageId String?
  currentStage   Stage?  @relation(fields: [currentStageId], references: [id])

  loginAccount           StaffUser?                      @relation("TraineeLogin")
  permissionScopes       UserPermissionOverride[]
  scoreEntries           ScoreEntry[]
  measurementReports     MeasurementReport[]
  stageChangeEvents      StageChangeEvent[]
  periodSnapshots        StagePeriodSnapshot[]
  parameterOverrides     TraineeParameterOverride[]
  thresholdOverrides     TraineeThresholdOverride[]
  groupMembershipHistory TraineeGroupMembershipHistory[]
  scoringProfiles        ScoringProfile[]
  vacations              VacationPeriod[]

  @@index([institutionId])
  @@index([groupId])
}

// ---------------------------------------------------------------------------
// Permissions: role defaults + per-user overrides (override wins; see resolvePermission)
// ---------------------------------------------------------------------------

enum PermissionAction {
  VIEW
  EDIT
  CHANGE_STAGE
  VIEW_REPORTS
  EDIT_SETTINGS
  MANAGE_PERMISSIONS
  MANAGE_GROUPS
  MANAGE_TRAINEES
  TRANSFER_TRAINEES
  ENTER_REPORTS
  EDIT_REPORTS
  MANAGE_STAGE_SETTINGS
  MANAGE_GROUP_SETTINGS
  MANAGE_TRAINEE_SETTINGS
  MANAGE_VACATIONS
}

enum PermissionEffect {
  ALLOW
  DENY
}

// Institution-wide default: does this role have this action allowed at all?
// Default posture per spec: only ADMIN has view access until explicitly configured otherwise.
model RolePermission {
  id            String           @id @default(cuid())
  institutionId String
  institution   Institution      @relation(fields: [institutionId], references: [id])
  role          StaffRole
  action        PermissionAction
  allowed       Boolean          @default(false)

  @@unique([institutionId, role, action])
}

// Per-user exception. Always wins over RolePermission for the same (staff, action, scope).
// scope = null means institution-wide for this action; groupId/traineeId narrow it.
// Exactly one of groupId/traineeId should be set, or neither — see resolvePermission for precedence
// among override rows when several could match.
model UserPermissionOverride {
  id            String           @id @default(cuid())
  institutionId String
  institution   Institution      @relation(fields: [institutionId], references: [id])
  staffId       String
  staff         StaffUser        @relation(fields: [staffId], references: [id])
  action        PermissionAction
  effect        PermissionEffect
  groupId       String?
  group         Group?           @relation(fields: [groupId], references: [id])
  traineeId     String?
  trainee       Trainee?         @relation(fields: [traineeId], references: [id])
  createdAt     DateTime         @default(now())

  @@index([institutionId, staffId, action])
}

// ---------------------------------------------------------------------------
// Stage Programs (תכניות שלבים) — the one domain specified in depth so far.
// ---------------------------------------------------------------------------

// A named, versioned stage-program configuration for an institution (or a single
// trainee's CUSTOM override — see TraineeParameterOverride/TraineeThresholdOverride).
// Every score/measurement/recommendation must reference the specific StageProgramVersion
// that was active when it was computed, so later config edits never rewrite history.
model StageProgram {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  createdAt     DateTime    @default(now())

  versions StageProgramVersion[]

  @@index([institutionId])
}

model StageProgramVersion {
  id                      String               @id @default(cuid())
  stageProgramId          String
  stageProgram            StageProgram         @relation(fields: [stageProgramId], references: [id])
  versionNumber           Int
  status                  ConfigurationStatus  @default(PUBLISHED)
  // Verbal description of the measurement method for this version (שיטת המדידה).
  measurementMethodNote   String?
  requiredMeasurementDays Int
  effectiveFrom           DateTime             @default(now())
  effectiveTo             DateTime?
  createdById             String?
  createdBy               StaffUser?           @relation("StageProgramVersionCreatedBy", fields: [createdById], references: [id])
  replacedById            String?              @unique
  replacedBy              StageProgramVersion? @relation("StageProgramVersionReplacement", fields: [replacedById], references: [id])
  replaces                StageProgramVersion? @relation("StageProgramVersionReplacement")
  replacedByUserId        String?
  replacedByUser          StaffUser?           @relation("StageProgramVersionReplacedBy", fields: [replacedByUserId], references: [id])
  replacedAt              DateTime?
  publishedAt             DateTime?
  createdAt               DateTime             @default(now())

  stages             Stage[]
  parameters         ParameterDefinition[]
  thresholds         StageThreshold[]
  scoringProfiles    ScoringProfile[]
  measurementReports MeasurementReport[]

  @@unique([stageProgramId, versionNumber])
  @@index([stageProgramId, status, effectiveFrom])
}

model Stage {
  id                    String              @id @default(cuid())
  stageProgramVersionId String
  stageProgramVersion   StageProgramVersion @relation(fields: [stageProgramVersionId], references: [id])
  order                 Int
  name                  String

  // Verbal rights/reinforcements/limits/goals for this stage (זכויות/חיזוקים/מגבלות/יעדים).
  // Free-form list; the system ships with no predefined set — authorized users add/remove entries.
  provisions StageProvision[]

  traineesCurrentlyHere    Trainee[]
  thresholdsFrom           StageThreshold[]           @relation("ThresholdFromStage")
  parameterOverrides       TraineeParameterOverride[]
  thresholdOverrides       TraineeThresholdOverride[]
  scoringProfileParameters ScoringProfileParameter[]
  periodSnapshots          StagePeriodSnapshot[]
  changeEventsTo           StageChangeEvent[]

  @@unique([stageProgramVersionId, order])
}

model StageProvision {
  id        String   @id @default(cuid())
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id])
  label     String
  createdAt DateTime @default(now())
}

// A measurable parameter within a stage-program version. Weights across all parameters
// for a given (stageProgramVersionId, stageId-or-null-for-all-stages) must sum to 100 —
// this is a cross-row invariant that belongs in the service layer. A pure validator
// exists for future write paths, but no stage-program create/update service exists
// today; only seed/tests write these rows.
model ParameterDefinition {
  id                           String                @id @default(cuid())
  stageProgramVersionId        String
  stageProgramVersion          StageProgramVersion   @relation(fields: [stageProgramVersionId], references: [id])
  // Null = applies to all stages in this version; set = this stage only.
  // (Spec allows parameters/thresholds to differ per stage.)
  stageId                      String?
  name                         String
  verbalDefinition             String?
  scoreScale                   ScoreScale            @default(ONE_TO_TEN)
  weightPercent                Decimal               @db.Decimal(5, 2)
  active                       Boolean               @default(true)
  displayOrder                 Int?
  deactivatedAt                DateTime?
  basedOnParameterDefinitionId String?
  basedOnParameterDefinition   ParameterDefinition?  @relation("ParameterDefinitionLineage", fields: [basedOnParameterDefinitionId], references: [id])
  derivedParameterDefinitions  ParameterDefinition[] @relation("ParameterDefinitionLineage")

  scoreEntries             ScoreEntry[]
  traineeOverrides         TraineeParameterOverride[]
  scoringProfileParameters ScoringProfileParameter[]

  @@index([stageProgramVersionId])
  @@index([stageProgramVersionId, active])
  @@index([basedOnParameterDefinitionId])
}

// Recommendation thresholds for a stage-program version (X/Y/Z from the spec).
// NOTE: boundary semantics (is "above Z" inclusive of Z? what happens exactly at the
// threshold? is there a "needs review" middle band?) are an OPEN PRODUCT QUESTION —
// not decided yet. Do not hardcode an interpretation; see src/services/stagePrograms/recommendation.ts.
model StageThreshold {
  id                    String              @id @default(cuid())
  stageProgramVersionId String
  stageProgramVersion   StageProgramVersion @relation(fields: [stageProgramVersionId], references: [id])
  // Null = applies to all stages in this version; set = this stage only.
  stageId               String?
  fromStage             Stage?              @relation("ThresholdFromStage", fields: [stageId], references: [id])
  decreaseBelow         Decimal             @db.Decimal(5, 2)
  increaseAbove         Decimal             @db.Decimal(5, 2)

  @@index([stageProgramVersionId])
}

// Per-trainee customization when measurementMode = CUSTOM. Overrides one parameter's
// weight/definition for that trainee only, still pinned to a specific version.
model TraineeParameterOverride {
  id                    String              @id @default(cuid())
  traineeId             String
  trainee               Trainee             @relation(fields: [traineeId], references: [id])
  parameterDefinitionId String
  parameterDefinition   ParameterDefinition @relation(fields: [parameterDefinitionId], references: [id])
  stageId               String?
  stage                 Stage?              @relation(fields: [stageId], references: [id])
  weightPercent         Decimal?            @db.Decimal(5, 2)
  verbalDefinition      String?
  createdAt             DateTime            @default(now())
}

// Per-trainee customization of recommendation thresholds when measurementMode = CUSTOM.
model TraineeThresholdOverride {
  id            String   @id @default(cuid())
  traineeId     String
  trainee       Trainee  @relation(fields: [traineeId], references: [id])
  stageId       String?
  stage         Stage?   @relation(fields: [stageId], references: [id])
  decreaseBelow Decimal  @db.Decimal(5, 2)
  increaseAbove Decimal  @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
}

// One parameter score for one trainee on one measurement day.
// status distinguishes NOT_APPLICABLE (removed from the 100% base) from NOT_SCORED
// (counted as 0) — see spec: "לא רלוונטי" vs "לא נוקד".
enum ParameterEntryStatus {
  SCORED
  NOT_SCORED
  NOT_APPLICABLE
}

enum ScoreScale {
  ONE_TO_THREE
  ONE_TO_TEN
  ONE_TO_ONE_HUNDRED
}

enum ConfigurationStatus {
  DRAFT
  PUBLISHED
  REPLACED
}

enum ReportStatus {
  DRAFT
  PUBLISHED
}

model ScoringProfile {
  id                    String               @id @default(cuid())
  institutionId         String
  institution           Institution          @relation(fields: [institutionId], references: [id])
  groupId               String?
  group                 Group?               @relation(fields: [groupId], references: [id])
  traineeId             String?
  trainee               Trainee?             @relation(fields: [traineeId], references: [id])
  stageProgramVersionId String?
  stageProgramVersion   StageProgramVersion? @relation(fields: [stageProgramVersionId], references: [id])
  name                  String?
  status                ConfigurationStatus  @default(DRAFT)
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  createdById           String?
  createdBy             StaffUser?           @relation("ScoringProfileCreatedBy", fields: [createdById], references: [id])
  publishedById         String?
  publishedBy           StaffUser?           @relation("ScoringProfilePublishedBy", fields: [publishedById], references: [id])
  publishedAt           DateTime?
  replacedById          String?              @unique
  replacedBy            ScoringProfile?      @relation("ScoringProfileReplacement", fields: [replacedById], references: [id])
  replaces              ScoringProfile?      @relation("ScoringProfileReplacement")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  parameters         ScoringProfileParameter[]
  measurementReports MeasurementReport[]

  @@index([institutionId, status, effectiveFrom])
  @@index([groupId])
  @@index([traineeId])
  @@index([stageProgramVersionId])
}

model ScoringProfileParameter {
  id                          String               @id @default(cuid())
  scoringProfileId            String
  scoringProfile              ScoringProfile       @relation(fields: [scoringProfileId], references: [id])
  sourceParameterDefinitionId String?
  sourceParameterDefinition   ParameterDefinition? @relation(fields: [sourceParameterDefinitionId], references: [id])
  stageId                     String?
  stage                       Stage?               @relation(fields: [stageId], references: [id])
  name                        String?
  verbalDefinition            String?
  scoreScale                  ScoreScale?
  weightPercent               Decimal?             @db.Decimal(5, 2)
  active                      Boolean              @default(true)
  displayOrder                Int?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  scoreEntries ScoreEntry[]

  @@unique([scoringProfileId, sourceParameterDefinitionId])
  @@index([scoringProfileId, active])
  @@index([sourceParameterDefinitionId])
  @@index([stageId])
}

model MeasurementReport {
  id                    String               @id @default(cuid())
  institutionId         String
  institution           Institution          @relation(fields: [institutionId], references: [id])
  traineeId             String
  trainee               Trainee              @relation(fields: [traineeId], references: [id])
  groupId               String?
  group                 Group?               @relation(fields: [groupId], references: [id])
  measurementDate       DateTime             @db.Date
  status                ReportStatus         @default(DRAFT)
  note                  String?
  isVacationOverride    Boolean              @default(false)
  stageProgramVersionId String?
  stageProgramVersion   StageProgramVersion? @relation(fields: [stageProgramVersionId], references: [id])
  scoringProfileId      String?
  scoringProfile        ScoringProfile?      @relation(fields: [scoringProfileId], references: [id])
  recordedById          String
  recordedBy            StaffUser            @relation("MeasurementReportRecordedBy", fields: [recordedById], references: [id])
  publishedById         String?
  publishedBy           StaffUser?           @relation("MeasurementReportPublishedBy", fields: [publishedById], references: [id])
  publishedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  scoreEntries ScoreEntry[]

  @@unique([traineeId, measurementDate])
  @@index([institutionId, measurementDate])
  @@index([groupId, measurementDate])
  @@index([status])
  @@index([stageProgramVersionId])
  @@index([scoringProfileId])
}

model ScoreEntry {
  id                        String                   @id @default(cuid())
  traineeId                 String
  trainee                   Trainee                  @relation(fields: [traineeId], references: [id])
  parameterDefinitionId     String?
  parameterDefinition       ParameterDefinition?     @relation(fields: [parameterDefinitionId], references: [id])
  scoringProfileParameterId String?
  scoringProfileParameter   ScoringProfileParameter? @relation(fields: [scoringProfileParameterId], references: [id])
  measurementReportId       String?
  measurementReport         MeasurementReport?       @relation(fields: [measurementReportId], references: [id])
  measurementDate           DateTime                 @db.Date
  status                    ParameterEntryStatus
  // Required only when status = SCORED. Validate against the parameter's ScoreScale.
  rawScore                  Int?
  recordedById              String
  recordedBy                StaffUser                @relation("ScoreEntryRecordedBy", fields: [recordedById], references: [id])
  createdAt                 DateTime                 @default(now())

  @@unique([traineeId, parameterDefinitionId, measurementDate])
  @@unique([traineeId, scoringProfileParameterId, measurementDate])
  @@unique([measurementReportId, parameterDefinitionId])
  @@unique([measurementReportId, scoringProfileParameterId])
  @@index([traineeId, measurementDate])
  @@index([measurementReportId])
  @@index([scoringProfileParameterId])
}

model VacationPeriod {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  groupId       String?
  group         Group?      @relation(fields: [groupId], references: [id])
  traineeId     String?
  trainee       Trainee?    @relation(fields: [traineeId], references: [id])
  title         String
  note          String?
  startsOn      DateTime    @db.Date
  endsOn        DateTime    @db.Date
  createdById   String?
  createdBy     StaffUser?  @relation("VacationCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId, startsOn, endsOn])
  @@index([groupId, startsOn, endsOn])
  @@index([traineeId, startsOn, endsOn])
}

model TraineeGroupMembershipHistory {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  traineeId     String
  trainee       Trainee     @relation(fields: [traineeId], references: [id])
  fromGroupId   String?
  fromGroup     Group?      @relation("MembershipFromGroup", fields: [fromGroupId], references: [id])
  toGroupId     String?
  toGroup       Group?      @relation("MembershipToGroup", fields: [toGroupId], references: [id])
  effectiveFrom DateTime    @db.Date
  movedById     String
  movedBy       StaffUser   @relation("GroupMovePerformedBy", fields: [movedById], references: [id])
  note          String?
  createdAt     DateTime    @default(now())

  @@index([institutionId, effectiveFrom])
  @@index([traineeId, effectiveFrom])
  @@index([fromGroupId])
  @@index([toGroupId])
}

enum StageRecommendation {
  INCREASE
  MAINTAIN
  DECREASE
}

// Automatic end-of-period snapshot of every trainee's stage, taken whether or not
// anything changed — this is what answers "what stage was X at on date Y".
model StagePeriodSnapshot {
  id         String   @id @default(cuid())
  traineeId  String
  trainee    Trainee  @relation(fields: [traineeId], references: [id])
  stageId    String
  stage      Stage    @relation(fields: [stageId], references: [id])
  periodEnd  DateTime @db.Date
  totalScore Decimal  @db.Decimal(5, 2)
  createdAt  DateTime @default(now())

  @@unique([traineeId, periodEnd])
}

// A recorded, actual stage change (distinct from a snapshot or a report recommendation).
model StageChangeEvent {
  id                   String              @id @default(cuid())
  traineeId            String
  trainee              Trainee             @relation(fields: [traineeId], references: [id])
  fromStageId          String?
  toStageId            String
  toStage              Stage               @relation(fields: [toStageId], references: [id])
  performedById        String
  performedBy          StaffUser           @relation("StageChangePerformedBy", fields: [performedById], references: [id])
  performedAt          DateTime            @default(now())
  totalScoreAtChange   Decimal             @db.Decimal(5, 2)
  systemRecommendation StageRecommendation
  note                 String?

  @@index([traineeId, performedAt])
}

// ---------------------------------------------------------------------------
// History / Audit
// ---------------------------------------------------------------------------

// History of edits to stage-program configuration (parameters, weights, thresholds,
// stage provisions, etc). One row per change; "what changed" kept as a JSON diff since
// the shape of what can change varies by entity.
model SettingsChangeLogEntry {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  changedById   String
  changedBy     StaffUser   @relation("SettingsChangedBy", fields: [changedById], references: [id])
  entityType    String
  entityId      String
  change        Json
  changedAt     DateTime    @default(now())

  @@index([institutionId, entityType, entityId])
}

// Append-only audit log for sensitive actions (permission changes, data access to
// sensitive reports, etc). Distinct from SettingsChangeLogEntry, which is specifically
// about stage-program configuration history.
model AuditLogEntry {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  actorId       String?
  actor         StaffUser?  @relation(fields: [actorId], references: [id])
  action        String
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([institutionId, createdAt])
}
