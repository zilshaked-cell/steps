# Copy to .env and fill in real values. Never commit .env itself.

DATABASE_URL="postgresql://steps:steps_dev_password@localhost:5432/steps_dev?schema=public"

# Auth.js session encryption secret. Generate with: npx auth secret
AUTH_SECRET=""

# Auth.js public origin used for OAuth redirects.
AUTH_URL="http://localhost:3000"

# Google OAuth client. Configure this redirect URI in Google Cloud:
# http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional local seed override. Set this to the Google account that should be the
# seeded staff users in development.
DEV_ADMIN_EMAIL="admin@example.local"
DEV_LEAD_EMAIL="lead@example.local"
DEV_COUNSELOR_EMAIL="counselor@example.local"
